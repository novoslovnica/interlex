generator client {
  provider = "prisma-client"
  output   = "./generated/data"
}

datasource db {
  provider = "sqlite"
}

model Lexeme {
  id              Int              @id @default(autoincrement())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  slug            String           @unique
  external_id     Int?
  value           String?
  transcription   String?
  mainCategory    String?
  usageType       String?
  pos             String?
  aspect          String?
  transitivity    String?
  animacy         String?
  degree          String?
  pronType        String?
  numType         String?
  frequency       String?
  intelligibility String?
  addition        String?
  sameInLanguages String?
  etymology       String?

  proto           String?
  paradigm        String?
  protoStemClass  String?
  stemExtension   String?
  genesis         String?

  // ПОЛЯ ДЛЯ АВТОМАТИЧЕСКОЙ ГЕНЕРАЦИИ ПАРАДИГМ
  stem            String?
  secondaryStem   String?
  tertiaryStem    String?
  governsCase     Int?               // 2=GEN, 3=DAT, 4=ACC, 5=INS, 6=LOC. В будущем отдельная таблица для множественности
  gender          String?
  declension      Int?
  conjugation     Int?
  stressPosition  Int?               // Ударный слог от начала слова (0=первый). Для paradigm A, override penultimate.

  // Имя собственное / нарицательное
  properNoun      Boolean          @default(false)

  // Маркер аномалий флексий
  hasAnomalies    Boolean          @default(false)

  // Частотность на основе корпусных данных
  corpusFrequency       Int?
  corpusFrequencyPerMln Float?
  corpusRank            Int?
  corpusHapax           Boolean?

  // CEFR уровень и метрики распределения
  distributionD         Float?    // Juilland's D coefficient (0.01–1.0)
  usageScore            Float?    // usage_score = f_ipm × D × k_slav
  cefrLevel             String?   // 'A1', 'A2', 'B1', 'B2', 'C1', 'C2'

  // Обратные связи Prisma
  meanings        Meaning[]
  lexemes_morphemes LexemeMorpheme[]
  anomalies       InflectionAnomaly[]
  lexemeAllophones   LexemeAllophone[]

  @@map("lexemes")
  @@index([slug])
  @@index([value])
}

model Candidate {
  id              Int      @id @default(autoincrement())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  value           String?
  isv             String?
  nsl             String?
  transcription   String?
  mainCategory    String?
  usageType       String?
  pos             String?
  aspect          String?
  transitivity    String?
  animacy         String?
  degree          String?
  pronType        String?
  numType         String?
  frequency       String?
  intelligibility String?
  addition        String?
  sameInLanguages String?
  etymology       String?
  proto           String?
  paradigm        String?
  protoStemClass  String?
  stemExtension   String?
  genesis         String?
  stem            String?
  secondaryStem   String?
  tertiaryStem    String?
  governsCase     Int?               // 2=GEN, 3=DAT, 4=ACC, 5=INS, 6=LOC
  gender          String?
  declension      Int?
  conjugation     Int?
  properNoun      Boolean          @default(false)
  hasAnomalies    Boolean          @default(false)
  promotedAt      DateTime?
  promotedToLexemeId Int?

  @@map("candidates")
  @@index([value])
  @@index([pos])
}

model Meaning {
  id       Int       @id @default(autoincrement())
  lexemeId   Int
  meaning  String?
  examples String?
  meaningVeryfied Int?
  meaningMessage  String?
  examplesVeryfied Int?
  examplesMessage  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Связь с таблицей лексем
  lexeme     Lexeme      @relation(fields: [lexemeId], references: [id], onDelete: Cascade)

  // Обратные связи для языковых таблиц
  en_word  En[]      @relation("EnWord")
  en_mean  En[]      @relation("EnMeaning")
  ru_word  Ru[]      @relation("RuWord")
  ru_mean  Ru[]      @relation("RuMeaning")
  mk_word  Mk[]      @relation("MkWord")
  mk_mean  Mk[]      @relation("MkMeaning")
  sr_word  Sr[]      @relation("SrWord")
  sr_mean  Sr[]      @relation("SrMeaning")
  uk_word  Uk[]      @relation("UkWord")
  uk_mean  Uk[]      @relation("UkMeaning")
  bg_word  Bg[]      @relation("BgWord")
  bg_mean  Bg[]      @relation("BgMeaning")
  pl_word  Pl[]      @relation("PlWord")
  pl_mean  Pl[]      @relation("PlMeaning")
  be_word  Be[]      @relation("BeWord")
  be_mean  Be[]      @relation("BeMeaning")
  cs_word  Cs[]      @relation("CsWord")
  cs_mean  Cs[]      @relation("CsMeaning")
  sk_word  Sk[]      @relation("SkWord")
  sk_mean  Sk[]      @relation("SkMeaning")
  sl_word  Sl[]      @relation("SlWord")
  sl_mean  Sl[]      @relation("SlMeaning")
  hr_word  Hr[]      @relation("HrWord")
  hr_mean  Hr[]      @relation("HrMeaning")
  cu_word  Cu[]      @relation("CuWord")
  cu_mean  Cu[]      @relation("CuMeaning")
  de_word  De[]      @relation("DeWord")
  de_mean  De[]      @relation("DeMeaning")
  nl_word  Nl[]      @relation("NlWord")
  nl_mean  Nl[]      @relation("NlMeaning")
  eo_word  Eo[]      @relation("EoWord")
  eo_mean  Eo[]      @relation("EoMeaning")
  hsb_word Hsb[]     @relation("HsbWord")
  hsb_mean Hsb[]     @relation("HsbMeaning")
  dsb_word Dsb[]     @relation("DsbWord")
  dsb_mean Dsb[]     @relation("DsbMeaning")

  // Связь с синсетами RuWordNet
  synsets  MeaningSynset[]

  // Консолидированная семантическая сеть (2026-07-23), заменяет собой
  // Synonym/Antonym/Hypernym/.../Conclusion выше для новых данных — см.
  // AGENTS.md "Semantic Network" секцию. Старые 11 таблиц пока не удалены.
  semanticRelationsSource SemanticRelation[] @relation("SemanticRelationSource")
  semanticRelationsTarget SemanticRelation[] @relation("SemanticRelationTarget")

  // NSM-семантические праймы (2026-07-23) — если это значение является
  // экспонентом одного из ~64 семантических праймов
  primeExponents PrimeExponent[]

  @@map("meanings")
  @@index([lexemeId])
}

model Morpheme {
  id    Int     @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  value String?
  type  Int?    @default(0)
  stressPosition Int?               // Какой слог внутри морфемы ударный (0=первый, NULL=нейтральный)

  lexemes_morphemes LexemeMorpheme[]
  morphemeAllophones  MorphemeAllophone[]

  @@map("morphemes")
}

model LexemeMorpheme {
  id     Int  @id @default(autoincrement())
  lexemeId Int?
  morphemeId Int?

  lexeme   Lexeme? @relation(fields: [lexemeId], references: [id], onDelete: Cascade)
  morpheme   Morpheme? @relation(fields: [morphemeId], references: [id], onDelete: Cascade)

  @@map("lexemes_morphemes")
}

model AllophoneFlavor {
  id          Int     @id @default(autoincrement())
  code        String  @unique
  label       String
  description String?
  lexemeAllophones   LexemeAllophone[]
  morphemeAllophones MorphemeAllophone[]
  endingAllophones   EndingAllophone[]
  @@map("allophone_flavors")
}

model LexemeAllophone {
  id        Int     @id @default(autoincrement())
  lexemeId  Int
  value     String
  flavorId  Int
  type      String  @default("standard")
  lexeme    Lexeme               @relation(fields: [lexemeId], references: [id], onDelete: Cascade)
  flavor    AllophoneFlavor      @relation(fields: [flavorId], references: [id], onDelete: Cascade)
  @@unique([lexemeId, flavorId, type])
  @@map("lexeme_allophones")
  @@index([lexemeId])
  @@index([flavorId])
}

model MorphemeAllophone {
  id         Int     @id @default(autoincrement())
  morphemeId Int
  value      String
  flavorId   Int
  morpheme   Morpheme             @relation(fields: [morphemeId], references: [id], onDelete: Cascade)
  flavor     AllophoneFlavor      @relation(fields: [flavorId], references: [id], onDelete: Cascade)
  @@unique([morphemeId, flavorId])
  @@map("morpheme_allophones")
  @@index([morphemeId])
  @@index([flavorId])
}

model EndingAllophone {
  id        Int     @id @default(autoincrement())
  stemType  String
  grammeme  String
  value     String
  flavorId  Int
  flavor    AllophoneFlavor @relation(fields: [flavorId], references: [id], onDelete: Cascade)
  @@unique([stemType, grammeme, flavorId])
  @@map("ending_allophones")
  @@index([flavorId])
}

// Динамические таблицы языков, преобразованные в схемы Prisma
model En {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  value     String?
  veryfied  Int?
  wordId    Int?
  meaningId Int?

  word      Meaning? @relation("EnWord", fields: [wordId], references: [id], onDelete: Cascade)
  meaning   Meaning? @relation("EnMeaning", fields: [meaningId], references: [id], onDelete: Cascade)

  message       String?

  @@map("en")
  @@index([wordId])
  @@index([meaningId])
}

