// Карта основ → массив lexemeId омонимов (хеш-таблица для префиксного поиска омонимов)
// base — текстовая основа (уникальный ключ), wordIds — JSON-строка с массивом ID лексем-омонимов
model BaseHomonym {
  id      Int    @id @default(autoincrement())
  base    String @unique // Основа (н-р: "vod" для "voda")
  wordIds String          // JSON-массив: "[1, 5, 12]"

  @@map("base_homonyms")
  @@index([base])
}

// Таблица аномалий флексий
// Хранит нестандартные флексии для конкретных слов
// Значение флексии (н-р: "-ami", "-ov")
// Ключ-склейка граммемы (н-р: "PL_INST", "PL_GEN")
model InflectionAnomaly {
  id         Int    @id @default(autoincrement())
  lexemeId     Int
  inflection String
  grammeme   String

  lexeme       Lexeme   @relation(fields: [lexemeId], references: [id], onDelete: Cascade)

  @@map("inflection_anomalies")
  @@index([lexemeId])
  @@index([grammeme])
}

model ProtoSlavicWord {
  id        Int    @id @default(autoincrement())
  lemma     String
  body      String @default("")
  sourceUrl String @default("") @map("source_url")

  @@map("proto_slavic_words")
  @@index([lemma])
}

// Синсеты RuWordNet — смысловые группы слов
model Synset {
  synsetId         String           @id
  synsetExternalId String?          @map("synset_external_id")
  definition       String?
  domains          String?
  semanticCodes    String?          @map("semantic_codes")
  partOfSpeech     String?          @map("part_of_speech")

  meanings         MeaningSynset[]

  @@map("synsets")
}

// Связь значений с синсетами
model MeaningSynset {
  meaningId  Int
  synsetId   String
  source     String?
  confidence Float?

  meaning    Meaning  @relation(fields: [meaningId], references: [id], onDelete: Cascade)
  synset     Synset   @relation(fields: [synsetId], references: [synsetId], onDelete: Cascade)

  @@id([meaningId, synsetId])
  @@map("meanings_synsets")
}

// Журнал изменений тезауруса (2026-07-25). Заменяет собой поле actionHistory,
// которое раньше дублировалось построчно в Lexeme/Candidate/Morpheme и во всех
// 18 языковых таблицах (в последних оно даже никогда не писалось — мёртвый вес).
// userId/userEmail хранятся как снимок, а не внешний ключ: User живёт в auth.db,
// в другой базе, а кросс-базовые связи в этом проекте намеренно не делаются —
// тот же принцип, что уже применялся к полю author в старом actionHistory.
model AuditLog {
  id         Int      @id @default(autoincrement())
  actionId   String   // группирует несколько изменённых полей одного сохранения в одно действие
  entityType String   // 'Lexeme' | 'Morpheme' | 'Candidate' | ...
  entityId   Int
  field      String
  oldValue   String?
  newValue   String?
  userId     String?
  userEmail  String
  createdAt  DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([userId, createdAt])
  @@index([actionId])
  @@map("audit_logs")
}

// Консолидированная семантическая сеть (2026-07-23). Заменяет собой 11 таблиц
// Synonym/Antonym/Hypernym/Hyponym/Meronym/Holonym/RelatedWord/Cause/Effect/
// Premise/Conclusion — одна строка на факт, направление кодируется через
// sourceId/targetId, а не отдельными зеркальными строками (см. AGENTS.md
// "Semantic Network" — прошлые hypernyms/hyponyms и т.п. генерировались
// независимо и могли расходиться).
// relationType — обычная строка, не БД-enum, чтобы новые типы можно было
// добавлять как данные без миграции схемы.
// Симметричные типы (порядок неважен, при записи нормализуется sourceId=min,
// targetId=max): synonym, antonym, related, pos_synonym.
// Направленные типы (source=частное/зависимое, target=общее/управляющее):
// hypernymy (source=гипоним→target=гипероним), meronymy (source=часть→
// target=целое), causation (source=причина→target=следствие), entailment
// (source=предпосылка→target=заключение), instance_of (source=экземпляр→
// target=класс), derivation (source=база→target=производное).
// Старые 11 таблиц пока не удалены — удаление отложено до переноса админки
// (см. AGENTS.md, "деферред TODO").
model SemanticRelation {
  id           Int      @id @default(autoincrement())
  sourceId     Int
  targetId     Int
  relationType String   @map("relation_type")
  proximity    Float?
  source       String   @default("manual")
  createdAt    DateTime @default(now()) @map("created_at")

  sourceMeaning Meaning @relation("SemanticRelationSource", fields: [sourceId], references: [id], onDelete: Cascade)
  targetMeaning Meaning @relation("SemanticRelationTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, relationType])
  @@index([sourceId, relationType])
  @@index([targetId, relationType])
  @@map("semantic_relations")
}

// NSM-семантические праймы (2026-07-23). Справочник ~64 универсальных
// неопределяемых смыслов (Goddard 2011 chart, см. AGENTS.md "Semantic
// Network" для точной цитаты и расхождения 64 vs широко цитируемых 65) —
// код праймов не меняется независимо от того, какие межславянские слова
// выбраны их экспонентами.
model SemanticPrime {
  code        String @id
  category    String?
  englishText String @map("english_text")
  sortOrder   Int    @map("sort_order")

  exponents PrimeExponent[]

  @@map("semantic_primes")
}

// Экспонент прайма — конкретное межславянское значение (Meaning), которое
// реализует данный прайм. Один прайм может иметь несколько аллолексов
// (разные поверхностные формы в разных грамматических контекстах — это
// заложено в саму теорию NSM, не ошибка), поэтому это join-таблица, а не
// прямой FK на SemanticPrime.
model PrimeExponent {
  id          Int     @id @default(autoincrement())
  primeCode   String  @map("prime_code")
  meaningId   Int
  isCanonical Boolean @default(true) @map("is_canonical")
  note        String?

  prime   SemanticPrime @relation(fields: [primeCode], references: [code], onDelete: Cascade)
  meaning Meaning       @relation(fields: [meaningId], references: [id], onDelete: Cascade)

  @@unique([primeCode, meaningId])
  @@index([meaningId])
  @@map("prime_exponents")
}