generator client {
  provider = "prisma-client"
  output   = "./generated/library"
}

datasource db {
  provider = "sqlite"
}

model LibraryEntry {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  author      String?
  genre       String   @default("article")
  topic       String?
  flavor      String   @default("CORE")

body       String?
  bodyLength Int      @default(0)

  source          String?
  yearWritten     Int?
  yearTranslated  Int?
  translator      String?

  addedById   String?
  addedBy     String?

  verified    Boolean  @default(false)
  verifiedBy  String?

  corpusSlug  String?

  summary     String?
  coverImage  String?
  audioFile   String?
  views       Int      @default(0)

  isPublic    Boolean  @default(true)
  parentId    Int?
  parent      LibraryEntry?  @relation("CollectionChildren", fields: [parentId], references: [id])
  children    LibraryEntry[] @relation("CollectionChildren")

  actionHistory String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}